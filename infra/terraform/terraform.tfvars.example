aws_region        = "us-east-1"
project_name      = "fintech-fraud-agent"
container_image   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/fintech-fraud-agent:latest"
schedule_expression = "rate(15 minutes)"

llm_provider = "openai_compatible"

# OpenAI-compatible mode
openai_base_url = "https://your-openai-compatible-endpoint.example.com"
openai_model    = "gpt-4.1-mini"
openai_api_key  = "replace-with-real-key"

# Azure AI Foundry mode (set llm_provider = "azure_foundry" to use these)
azure_endpoint    = "https://your-foundry-resource.openai.azure.com/"
azure_deployment  = "your-deployment-name"
azure_api_version = "2024-10-21"
azure_api_key     = "replace-with-real-azure-key"

dataset_path = "fintech.csv"
report_path  = "samples/sample_report.txt"
random_state = 42
